# Build rule for target.
ocudu_ldpc: cmake_check_build_system
	$(MAKE) $(MAKESILENT) -f CMakeFiles/Makefile2 ocudu_ldpc
.PHONY : ocudu_ldpc

# fast build rule for target.
ocudu_ldpc/fast:
	$(MAKE) $(MAKESILENT) -f lib/phy/upper/channel_coding/ldpc/CMakeFiles/ocudu_ldpc.dir/build.make lib/phy/upper/channel_coding/ldpc/CMakeFiles/ocudu_ldpc.dir/build
.PHONY : ocudu_ldpc/fast

