{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "mbsSessionRef": {
      "type": "string",
      "minLength": 1
    },
    "mbsSession": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "mbsSessionId": {
          "type": "object"
        },
        "tmgi": {
          "type": "object"
        },
        "serviceType": {
          "type": "string",
          "enum": [
            "BROADCAST",
            "MULTICAST"
          ]
        }
      },
      "required": [
        "serviceType"
      ],
      "anyOf": [
        {
          "required": [
            "mbsSessionId"
          ]
        },
        {
          "required": [
            "tmgi"
          ]
        }
      ]
    }
  },
  "required": [
    "mbsSession"
  ]
}
