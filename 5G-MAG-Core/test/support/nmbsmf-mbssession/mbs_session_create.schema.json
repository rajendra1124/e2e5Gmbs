{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "mbsSession": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "mbsSessionId": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "tmgi": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "mbsServiceId": {
                  "type": "string",
                  "pattern": "^[A-Fa-f0-9]{6}$"
                },
                "plmnId": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "mcc": {
                      "type": "string",
                      "pattern": "^[0-9]{3}$"
                    },
                    "mnc": {
                      "type": "string",
                      "pattern": "^[0-9]{2,3}$"
                    }
                  },
                  "required": [
                    "mcc",
                    "mnc"
                  ]
                }
              },
              "required": [
                "mbsServiceId",
                "plmnId"
              ]
            },
            "nid": {
              "type": "string",
              "pattern": "^[A-Fa-f0-9]{11}$"
            }
          },
          "required": [
            "tmgi"
          ]
        },
        "serviceType": {
          "type": "string",
          "enum": [
            "BROADCAST",
            "MULTICAST"
          ]
        }
      },
      "required": [
        "mbsSessionId",
        "serviceType"
      ]
    }
  },
  "required": [
    "mbsSession"
  ]
}
